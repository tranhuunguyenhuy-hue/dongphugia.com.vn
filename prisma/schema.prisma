/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id                Int                 @id @default(autoincrement())
  sku               String              @unique @db.VarChar(50)
  name              String              @db.VarChar(200)
  slug              String              @unique @db.VarChar(200)
  pattern_type_id   Int
  collection_id     Int?
  surface_id        Int?
  size_id           Int?
  origin_id         Int?
  description       String?
  price_display     String?             @default("Liên hệ báo giá") @db.VarChar(50)
  image_main_url    String?             @db.VarChar(500)
  image_hover_url   String?             @db.VarChar(500)
  is_active         Boolean?            @default(true)
  is_featured       Boolean?            @default(false)
  sort_order        Int?                @default(0)
  seo_title         String?             @db.VarChar(200)
  seo_description   String?             @db.VarChar(500)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  updated_at        DateTime?           @default(now()) @db.Timestamp(6)
  product_colors    product_colors[]
  product_images    product_images[]
  product_locations product_locations[]
  collections       collections?        @relation(fields: [collection_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  origins           origins?            @relation(fields: [origin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pattern_types     pattern_types       @relation(fields: [pattern_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sizes             sizes?              @relation(fields: [size_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  surfaces          surfaces?           @relation(fields: [surface_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quote_requests    quote_requests[]

  @@index([is_active], map: "idx_products_active")
  @@index([collection_id], map: "idx_products_collection")
  @@index([origin_id], map: "idx_products_origin")
  @@index([pattern_type_id], map: "idx_products_pattern_type")
  @@index([size_id], map: "idx_products_size")
  @@index([surface_id], map: "idx_products_surface")
}

