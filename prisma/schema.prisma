generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model banners {
  id         Int       @id @default(autoincrement())
  title      String?   @db.VarChar(200)
  image_url  String    @db.VarChar(500)
  link_url   String?   @db.VarChar(500)
  is_active  Boolean   @default(true)
  sort_order Int       @default(0)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model collections {
  id              Int           @id @default(autoincrement())
  pattern_type_id Int
  name            String        @db.VarChar(100)
  slug            String        @unique @db.VarChar(100)
  tagline         String?       @db.VarChar(200)
  description     String?
  thumbnail_url   String?       @db.VarChar(500)
  is_active       Boolean?      @default(true)
  is_featured     Boolean?      @default(false)
  sort_order      Int?          @default(0)
  created_at      DateTime?     @default(now()) @db.Timestamp(6)
  updated_at      DateTime?     @default(now()) @db.Timestamp(6)
  pattern_types   pattern_types @relation(fields: [pattern_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products        products[]

  @@index([pattern_type_id], map: "idx_collections_pattern_type")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model colors {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(50)
  slug           String           @unique @db.VarChar(50)
  hex_code       String?          @db.VarChar(7)
  bep_products   bep_products[]
  nuoc_products  nuoc_products[]
  product_colors product_colors[]
  sango_products sango_products[]
  tbvs_products  tbvs_products[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
