generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model banners {
  id         Int       @id @default(autoincrement())
  title      String?   @db.VarChar(200)
  image_url  String    @db.VarChar(500)
  link_url   String?   @db.VarChar(500)
  is_active  Boolean   @default(true)
  sort_order Int       @default(0)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model colors {
  id       Int        @id @default(autoincrement())
  name     String     @db.VarChar(50)
  slug     String     @unique @db.VarChar(50)
  hex_code String?    @db.VarChar(7)
  products products[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model origins {
  id       Int        @id @default(autoincrement())
  name     String     @db.VarChar(100)
  slug     String     @unique @db.VarChar(100)
  products products[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_images {
  id         Int      @id @default(autoincrement())
  product_id Int
  image_url  String   @db.VarChar(1000)
  alt_text   String?  @db.VarChar(300)
  image_type String   @default("gallery") @db.VarChar(20)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_product_images_product")
  @@index([image_type], map: "idx_product_images_type")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id                     Int                      @id @default(autoincrement())
  sku                    String                   @unique @db.VarChar(100)
  name                   String                   @db.VarChar(500)
  slug                   String                   @db.VarChar(500)
  category_id            Int
  subcategory_id         Int?
  brand_id               Int?
  origin_id              Int?
  color_id               Int?
  material_id            Int?
  price                  Decimal?                 @db.Decimal(15, 2)
  price_display          String?                  @default("Liên hệ báo giá") @db.VarChar(50)
  description            String?
  features               String?
  specs                  Json                     @default("{}")
  warranty_months        Int?
  image_main_url         String?                  @db.VarChar(1000)
  image_hover_url        String?                  @db.VarChar(1000)
  stock_status           String                   @default("in_stock") @db.VarChar(20)
  is_active              Boolean                  @default(true)
  is_featured            Boolean                  @default(false)
  is_new                 Boolean                  @default(false)
  is_bestseller          Boolean                  @default(false)
  sort_order             Int                      @default(0)
  source_url             String?                  @db.VarChar(1000)
  hita_product_id        String?                  @db.VarChar(100)
  seo_title              String?                  @db.VarChar(200)
  seo_description        String?                  @db.VarChar(500)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  order_items            order_items[]
  product_feature_values product_feature_values[]
  product_images         product_images[]
  quote_items            quote_items[]
  brands                 brands?                  @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  categories             categories               @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  colors                 colors?                  @relation(fields: [color_id], references: [id], onUpdate: NoAction)
  materials              materials?               @relation(fields: [material_id], references: [id], onUpdate: NoAction)
  origins                origins?                 @relation(fields: [origin_id], references: [id], onUpdate: NoAction)
  subcategories          subcategories?           @relation(fields: [subcategory_id], references: [id], onUpdate: NoAction)

  @@unique([category_id, slug])
  @@index([is_active], map: "idx_products_active")
  @@index([is_bestseller], map: "idx_products_bestseller")
  @@index([brand_id], map: "idx_products_brand")
  @@index([category_id], map: "idx_products_category")
  @@index([created_at(sort: Desc)], map: "idx_products_created")
  @@index([is_featured], map: "idx_products_featured")
  @@index([hita_product_id], map: "idx_products_hita_id")
  @@index([is_new], map: "idx_products_is_new")
  @@index([sort_order], map: "idx_products_sort")
  @@index([specs], map: "idx_products_specs", type: Gin)
  @@index([subcategory_id], map: "idx_products_subcategory")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model redirects {
  id          Int       @id @default(autoincrement())
  old_url     String    @unique @db.VarChar(500)
  new_url     String    @db.VarChar(500)
  status_code Int?      @default(301)
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model quote_requests {
  id            Int           @id @default(autoincrement())
  quote_number  String?       @unique @db.VarChar(30)
  name          String        @db.VarChar(100)
  phone         String        @db.VarChar(20)
  email         String?       @db.VarChar(200)
  message       String?
  status        String        @default("pending") @db.VarChar(20)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)
  quote_items   quote_items[]

  @@index([quote_number], map: "idx_quote_requests_number")
  @@index([created_at(sort: Desc)], map: "idx_quote_requests_created")
  @@index([status], map: "idx_quote_requests_status")
  @@index([phone], map: "idx_quote_requests_phone")
}

model quote_items {
  id             Int            @id @default(autoincrement())
  quote_id       Int
  product_id     Int
  quantity       Int            @default(1)
  note           String?        @db.VarChar(500)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  quote_requests quote_requests @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  products       products       @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([quote_id], map: "idx_quote_items_quote")
  @@index([product_id], map: "idx_quote_items_product")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_categories {
  id              Int          @id @default(autoincrement())
  name            String       @db.VarChar(100)
  slug            String       @unique @db.VarChar(100)
  description     String?
  thumbnail_url   String?
  is_active       Boolean      @default(true)
  sort_order      Int          @default(0)
  seo_title       String?      @db.VarChar(200)
  seo_description String?      @db.VarChar(500)
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime     @default(now()) @db.Timestamptz(6)
  blog_posts      blog_posts[]

  @@index([slug], map: "idx_blog_categories_slug")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_post_tags {
  post_id    Int
  tag_id     Int
  blog_posts blog_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  blog_tags  blog_tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, tag_id])
  @@index([post_id], map: "idx_blog_post_tags_post")
  @@index([tag_id], map: "idx_blog_post_tags_tag")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_posts {
  id              Int              @id @default(autoincrement())
  title           String           @db.VarChar(300)
  slug            String           @unique @db.VarChar(300)
  excerpt         String?
  content         String           @default("")
  category_id     Int
  thumbnail_url   String?
  cover_image_url String?
  seo_title       String?          @db.VarChar(200)
  seo_description String?          @db.VarChar(500)
  seo_keywords    String?          @db.VarChar(500)
  reading_time    Int?
  view_count      Int              @default(0)
  status          String           @default("draft") @db.VarChar(20)
  published_at    DateTime?        @db.Timestamptz(6)
  author_name     String           @default("Đông Phú Gia") @db.VarChar(100)
  author_avatar   String?
  is_featured     Boolean          @default(false)
  is_pinned       Boolean          @default(false)
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime         @default(now()) @db.Timestamptz(6)
  blog_post_tags  blog_post_tags[]
  blog_categories blog_categories  @relation(fields: [category_id], references: [id], onUpdate: NoAction)

  @@index([category_id], map: "idx_blog_posts_category")
  @@index([is_featured], map: "idx_blog_posts_featured")
  @@index([published_at], map: "idx_blog_posts_published")
  @@index([slug], map: "idx_blog_posts_slug")
  @@index([status], map: "idx_blog_posts_status")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_tags {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(50)
  slug           String           @unique @db.VarChar(50)
  description    String?
  post_count     Int              @default(0)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  blog_post_tags blog_post_tags[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model partners {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(200)
  slug           String    @unique @db.VarChar(200)
  logo_url       String?   @db.VarChar(500)
  description    String?
  tier           String?   @default("Vàng") @db.VarChar(50)
  gradient_class String?   @db.VarChar(100)
  link_url       String?   @db.VarChar(500)
  is_active      Boolean?  @default(true)
  sort_order     Int?      @default(0)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)

  @@index([is_active], map: "idx_partners_active")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model projects {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(200)
  slug          String    @unique @db.VarChar(200)
  location      String?   @db.VarChar(200)
  thumbnail_url String?   @db.VarChar(500)
  description   String?
  category      String?   @db.VarChar(100)
  tags          String[]  @default([])
  is_featured   Boolean?  @default(false)
  is_active     Boolean?  @default(true)
  sort_order    Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@index([is_active], map: "idx_projects_active")
  @@index([is_featured], map: "idx_projects_featured")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model brands {
  id             Int        @id @default(autoincrement())
  name           String     @db.VarChar(200)
  slug           String     @unique @db.VarChar(200)
  logo_url       String?    @db.VarChar(1000)
  description    String?
  origin_country String?    @db.VarChar(100)
  website_url    String?    @db.VarChar(500)
  is_active      Boolean    @default(true)
  is_featured    Boolean    @default(false)
  sort_order     Int        @default(0)
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime   @default(now()) @db.Timestamptz(6)
  products       products[]

  @@index([is_active], map: "idx_brands_active")
  @@index([is_featured], map: "idx_brands_featured")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id                 Int                  @id @default(autoincrement())
  name               String               @db.VarChar(100)
  slug               String               @unique @db.VarChar(100)
  description        String?
  thumbnail_url      String?              @db.VarChar(1000)
  icon_name          String?              @db.VarChar(50)
  is_active          Boolean              @default(true)
  sort_order         Int                  @default(0)
  seo_title          String?              @db.VarChar(200)
  seo_description    String?              @db.VarChar(500)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  filter_definitions filter_definitions[]
  products           products[]
  subcategories      subcategories[]

  @@index([is_active], map: "idx_categories_active")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model filter_definitions {
  id             Int            @id @default(autoincrement())
  category_id    Int?
  subcategory_id Int?
  filter_key     String         @db.VarChar(100)
  filter_label   String         @db.VarChar(200)
  filter_type    String         @default("select") @db.VarChar(50)
  options        Json?
  sort_order     Int            @default(0)
  is_active      Boolean        @default(true)
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  categories     categories?    @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subcategories  subcategories? @relation(fields: [subcategory_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category_id], map: "idx_filter_def_category")
  @@index([subcategory_id], map: "idx_filter_def_subcategory")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model materials {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  description String?
  sort_order  Int        @default(0)
  products    products[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model order_items {
  id           Int      @id @default(autoincrement())
  order_id     Int
  product_id   Int
  product_name String   @db.VarChar(500)
  product_sku  String   @db.VarChar(100)
  quantity     Int      @default(1)
  unit_price   Decimal  @db.Decimal(15, 2)
  total_price  Decimal  @db.Decimal(15, 2)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  orders       orders   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products     products @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order")
  @@index([product_id], map: "idx_order_items_product")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model orders {
  id               Int           @id @default(autoincrement())
  order_number     String        @unique @db.VarChar(20)
  customer_name    String        @db.VarChar(200)
  customer_phone   String        @db.VarChar(20)
  customer_email   String?       @db.VarChar(200)
  customer_address String?
  note             String?
  subtotal         Decimal       @default(0) @db.Decimal(15, 2)
  shipping_fee     Decimal       @default(0) @db.Decimal(15, 2)
  total            Decimal       @default(0) @db.Decimal(15, 2)
  status           String        @default("pending") @db.VarChar(30)
  payment_method   String?       @db.VarChar(50)
  payment_status   String        @default("unpaid") @db.VarChar(30)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @default(now()) @db.Timestamptz(6)
  order_items      order_items[]

  @@index([created_at(sort: Desc)], map: "idx_orders_created")
  @@index([order_number], map: "idx_orders_number")
  @@index([payment_status], map: "idx_orders_payment")
  @@index([status], map: "idx_orders_status")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_feature_values {
  id               Int              @id @default(autoincrement())
  product_id       Int
  feature_id       Int
  value            String?          @db.VarChar(500)
  product_features product_features @relation(fields: [feature_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         products         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, feature_id])
  @@index([feature_id], map: "idx_pfv_feature")
  @@index([product_id], map: "idx_pfv_product")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_features {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @db.VarChar(100)
  slug                   String                   @unique @db.VarChar(100)
  icon_name              String?                  @db.VarChar(50)
  description            String?
  sort_order             Int                      @default(0)
  product_feature_values product_feature_values[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subcategories {
  id                 Int                  @id @default(autoincrement())
  category_id        Int
  name               String               @db.VarChar(200)
  slug               String               @db.VarChar(200)
  description        String?
  thumbnail_url      String?              @db.VarChar(1000)
  hero_image_url     String?              @db.VarChar(1000)
  icon_name          String?              @db.VarChar(50)
  is_active          Boolean              @default(true)
  sort_order         Int                  @default(0)
  seo_title          String?              @db.VarChar(200)
  seo_description    String?              @db.VarChar(500)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  filter_definitions filter_definitions[]
  products           products[]
  categories         categories           @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([category_id, slug])
  @@index([is_active], map: "idx_subcategories_active")
  @@index([category_id], map: "idx_subcategories_category")
}
