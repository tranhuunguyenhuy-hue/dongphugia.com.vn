generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model banners {
  id          Int         @id @default(autoincrement())
  title       String?     @db.VarChar(200)
  image_url   String      @db.VarChar(500)
  link_url    String?     @db.VarChar(500)
  is_active   Boolean     @default(true)
  sort_order  Int         @default(0)
  created_at  DateTime?   @default(now()) @db.Timestamp(6)
  updated_at  DateTime?   @default(now()) @db.Timestamp(6)
  brand_id    Int?
  category_id Int?
  position    String?     @default("HERO") @db.VarChar(50)
  brands      brands?     @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  categories  categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model colors {
  id       Int        @id @default(autoincrement())
  name     String     @db.VarChar(50)
  slug     String     @unique @db.VarChar(50)
  hex_code String?    @db.VarChar(7)
  products products[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model origins {
  id       Int        @id @default(autoincrement())
  name     String     @db.VarChar(100)
  slug     String     @unique @db.VarChar(100)
  products products[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_images {
  id         Int      @id @default(autoincrement())
  product_id Int
  image_url  String   @db.VarChar(1000)
  alt_text   String?  @db.VarChar(300)
  image_type String   @default("gallery") @db.VarChar(20)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_product_images_product")
  @@index([image_type], map: "idx_product_images_type")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id                      Int                               @id @default(autoincrement())
  sku                     String                            @unique @db.VarChar(100)
  name                    String                            @db.VarChar(500)
  slug                    String                            @db.VarChar(500)
  category_id             Int
  subcategory_id          Int?
  brand_id                Int?
  origin_id               Int?
  color_id                Int?
  material_id             Int?
  price                   Decimal?                          @db.Decimal(15, 2)
  price_display           String?                           @default("Liên hệ báo giá") @db.VarChar(50)
  description             String?
  features                String?
  specs                   Json                              @default("{}")
  warranty_months         Int?
  image_main_url          String?                           @db.VarChar(1000)
  stock_status            String                            @default("in_stock") @db.VarChar(20)
  publication_status      String                            @default("public") @db.VarChar(30)
  pdp_visibility          String                            @default("public") @db.VarChar(30)
  listing_visibility      String                            @default("default") @db.VarChar(30)
  search_visibility       String                            @default("visible") @db.VarChar(30)
  listing_tier            Int                               @default(2)
  listing_priority        Int                               @default(0)
  listing_reason          String?                           @db.VarChar(50)
  data_quality_score      Int                               @default(0)
  sale_status             String                            @default("available") @db.VarChar(40)
  price_state             String                            @default("unknown") @db.VarChar(40)
  list_price              Decimal?                          @db.Decimal(15, 2)
  sale_price              Decimal?                          @db.Decimal(15, 2)
  price_source            String                            @default("unknown") @db.VarChar(40)
  price_confidence        String                            @default("medium") @db.VarChar(40)
  price_updated_at        DateTime?                         @db.Timestamptz(6)
  sellable_status         String                            @default("sellable") @db.VarChar(40)
  seo_indexing            String                            @default("index") @db.VarChar(40)
  sitemap_include         Boolean                           @default(true)
  canonical_product_id    Int?
  source_system           String                            @default("hita") @db.VarChar(40)
  source_confidence       String                            @default("medium") @db.VarChar(40)
  last_crawled_at         DateTime?                         @db.Timestamptz(6)
  crawl_status            String                            @default("fresh") @db.VarChar(40)
  is_active               Boolean                           @default(true)
  is_featured             Boolean                           @default(false)
  sort_order              Int                               @default(0)
  source_url              String?                           @db.VarChar(1000)
  hita_product_id         String?                           @db.VarChar(100)
  seo_title               String?                           @db.VarChar(200)
  seo_description         String?                           @db.VarChar(500)
  created_at              DateTime                          @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                          @default(now()) @db.Timestamptz(6)
  product_type            String?                           @db.VarChar(50)
  product_sub_type        String?                           @db.VarChar(50)
  component_skus          String[]                          @default([])
  display_name            String?                           @db.VarChar(500)
  original_price          Decimal?                          @db.Decimal(15, 2)
  search_vector           Unsupported("tsvector")?
  is_combo                Boolean                           @default(false)
  variant_group           String?                           @db.VarChar(50)
  is_promotion            Boolean                           @default(false)
  online_discount_amount  Decimal?                          @db.Decimal(15, 2)
  is_master               Boolean                           @default(true)
  is_home_featured        Boolean                           @default(false)
  variant_type            String?                           @db.VarChar(30)
  variant_label           String?                           @db.VarChar(100)
  variant_options         Json                              @default("[]")
  product_type_id         Int?
  product_sub_type_id     Int?
  variant_group_id        Int?
  order_items             order_items[]
  crawl_import_decisions  crawl_import_decisions[]          @relation("import_decision_target_product")
  package_child_items     product_package_items[]           @relation("package_child")
  package_items           product_package_items[]           @relation("package_parent")
  product_descriptions    product_descriptions?
  product_documents       product_documents[]
  product_feature_values  product_feature_values[]
  product_images          product_images[]
  product_spec_values     product_spec_values[]
  canonical_children      products[]                         @relation("products_canonical_product")
  canonical_product       products?                          @relation("products_canonical_product", fields: [canonical_product_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  child_relationships     product_relationships[]           @relation("child_relationships")
  parent_relationships    product_relationships[]           @relation("parent_relationships")
  product_source_mappings product_source_mappings[]
  secondary_subcategories product_secondary_subcategories[]
  brands                  brands?                           @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  categories              categories                        @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  colors                  colors?                           @relation(fields: [color_id], references: [id], onUpdate: NoAction)
  materials               materials?                        @relation(fields: [material_id], references: [id], onUpdate: NoAction)
  origins                 origins?                          @relation(fields: [origin_id], references: [id], onUpdate: NoAction)
  product_sub_types       product_sub_types?                @relation(fields: [product_sub_type_id], references: [id], onUpdate: NoAction)
  product_types           product_types?                    @relation(fields: [product_type_id], references: [id], onUpdate: NoAction)
  product_variant_groups  product_variant_groups?           @relation(fields: [variant_group_id], references: [id], onUpdate: NoAction)
  subcategories           subcategories?                    @relation(fields: [subcategory_id], references: [id], onUpdate: NoAction)
  quote_items             quote_items[]

  @@unique([category_id, slug])
  @@index([is_active], map: "idx_products_active")
  @@index([is_promotion], map: "idx_products_promotion")
  @@index([canonical_product_id], map: "idx_products_canonical_product")
  @@index([brand_id], map: "idx_products_brand")
  @@index([category_id], map: "idx_products_category")
  @@index([created_at(sort: Desc)], map: "idx_products_created")
  @@index([is_featured], map: "idx_products_featured")
  @@index([is_home_featured], map: "idx_products_home_featured")
  @@index([hita_product_id], map: "idx_products_hita_id")
  @@index([sort_order], map: "idx_products_sort")
  @@index([specs], map: "idx_products_specs", type: Gin)
  @@index([subcategory_id], map: "idx_products_subcategory")
  @@index([subcategory_id, product_type], map: "idx_products_sub_type_active")
  @@index([product_type], map: "idx_products_product_type")
  @@index([is_combo], map: "idx_products_is_combo")
  @@index([variant_group], map: "idx_products_variant_group")
  @@index([product_type_id], map: "idx_products_product_type_id")
  @@index([product_sub_type_id], map: "idx_products_product_sub_type_id")
  @@index([variant_group_id], map: "idx_products_variant_group_id")
  @@index([subcategory_id, product_type_id, is_active], map: "idx_products_sub_typeid_active")
  @@index([product_sub_type_id, is_active], map: "idx_products_subtypeid_active")
  @@index([publication_status, listing_visibility, listing_tier, listing_priority(sort: Desc)], map: "idx_products_public_listing")
  @@index([publication_status, search_visibility], map: "idx_products_search_visibility")
  @@index([seo_indexing, sitemap_include], map: "idx_products_seo")
  @@index([sale_status, price_state], map: "idx_products_sale_status")
}

model product_relationships {
  id                Int       @id @default(autoincrement())
  parent_id         Int
  child_sku         String    @db.VarChar(200)
  child_id          Int?
  relationship_type String    @default("component") @db.VarChar(50)
  sort_order        Int       @default(0)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  component_type    String    @default("component") @db.VarChar(30)
  quantity          Int?
  resolution_status String    @default("unresolved") @db.VarChar(30)
  source            String?   @db.VarChar(50)
  child             products? @relation("child_relationships", fields: [child_id], references: [id])
  parent            products  @relation("parent_relationships", fields: [parent_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, child_sku, relationship_type], name: "uq_product_rel", map: "uq_product_rel")
  @@index([parent_id], map: "idx_prel_parent")
  @@index([child_id], map: "idx_prel_child")
  @@index([child_sku], map: "idx_prel_child_sku")
  @@index([component_type], map: "idx_prel_component_type")
  @@index([resolution_status], map: "idx_prel_resolution_status")
}

model product_types {
  id                 Int                  @id @default(autoincrement())
  subcategory_id     Int
  slug               String               @db.VarChar(100)
  name               String               @db.VarChar(200)
  description        String?
  sort_order         Int                  @default(0)
  is_active          Boolean              @default(true)
  filter_policy      Json                 @default("{}")
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  products           products[]
  sub_types          product_sub_types[]
  subcategories      subcategories        @relation(fields: [subcategory_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  filter_definitions filter_definitions[]

  @@unique([subcategory_id, slug], map: "uq_product_types_sub_slug")
  @@index([subcategory_id], map: "idx_product_types_subcategory")
  @@index([is_active], map: "idx_product_types_active")
}

model product_sub_types {
  id              Int           @id @default(autoincrement())
  product_type_id Int
  slug            String        @db.VarChar(100)
  name            String        @db.VarChar(200)
  sort_order      Int           @default(0)
  is_active       Boolean       @default(true)
  products        products[]
  product_types   product_types @relation(fields: [product_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_type_id, slug], map: "uq_product_sub_types_type_slug")
  @@index([product_type_id], map: "idx_product_sub_types_type")
  @@index([is_active], map: "idx_product_sub_types_active")
}

model spec_definitions {
  id                 Int                   @id @default(autoincrement())
  key                String                @unique @db.VarChar(120)
  label              String                @db.VarChar(200)
  data_type          String                @default("text") @db.VarChar(30)
  unit               String?               @db.VarChar(30)
  is_filterable      Boolean               @default(false)
  is_pdp_visible     Boolean               @default(true)
  is_reserved        Boolean               @default(false)
  sort_order         Int                   @default(0)
  normalize_rule     Json                  @default("{}")
  created_at         DateTime              @default(now()) @db.Timestamptz(6)
  updated_at         DateTime              @default(now()) @db.Timestamptz(6)
  filter_definitions filter_definitions[]
  options            spec_options[]
  values             product_spec_values[]

  @@index([is_filterable], map: "idx_spec_definitions_filterable")
  @@index([is_pdp_visible], map: "idx_spec_definitions_pdp_visible")
}

model spec_options {
  id                  Int                   @id @default(autoincrement())
  spec_definition_id  Int
  value               String                @db.VarChar(200)
  slug                String                @db.VarChar(160)
  sort_order          Int                   @default(0)
  aliases             String[]              @default([])
  is_active           Boolean               @default(true)
  spec_definitions    spec_definitions      @relation(fields: [spec_definition_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_spec_values product_spec_values[]

  @@unique([spec_definition_id, slug], map: "uq_spec_options_definition_slug")
  @@index([spec_definition_id], map: "idx_spec_options_definition")
  @@index([spec_definition_id, value], map: "idx_spec_options_definition_value")
  @@index([is_active], map: "idx_spec_options_active")
}

model product_spec_values {
  id                 Int              @id @default(autoincrement())
  product_id         Int
  spec_definition_id Int
  option_id          Int?
  value_text         String?          @db.VarChar(500)
  value_number       Decimal?         @db.Decimal(15, 4)
  value_json         Json?
  raw_key            String?          @db.VarChar(200)
  raw_value          String?
  source             String           @default("manual") @db.VarChar(50)
  confidence         String           @default("medium") @db.VarChar(20)
  sort_order         Int              @default(0)
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  updated_at         DateTime         @default(now()) @db.Timestamptz(6)
  products           products         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  spec_definitions   spec_definitions @relation(fields: [spec_definition_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  spec_options       spec_options?    @relation(fields: [option_id], references: [id], onUpdate: NoAction)

  @@unique([product_id, spec_definition_id, option_id], map: "uq_product_spec_option")
  @@index([product_id], map: "idx_product_spec_values_product")
  @@index([spec_definition_id, option_id], map: "idx_product_spec_values_definition_option")
  @@index([spec_definition_id, value_text], map: "idx_product_spec_values_definition_text")
  @@index([value_text], map: "idx_product_spec_values_text")
  @@index([source], map: "idx_product_spec_values_source")
}

model product_documents {
  id            Int      @id @default(autoincrement())
  product_id    Int
  name          String   @db.VarChar(200)
  url           String   @db.VarChar(1000)
  source_url    String?  @db.VarChar(1000)
  document_type String   @default("DOCUMENT") @db.VarChar(30)
  file_ext      String?  @db.VarChar(20)
  file_size     Int?
  sort_order    Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  products      products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, url], map: "uq_product_documents_product_url")
  @@index([product_id], map: "idx_product_documents_product")
  @@index([document_type], map: "idx_product_documents_type")
}

model product_package_items {
  id                Int       @id @default(autoincrement())
  product_id        Int
  label             String    @db.VarChar(300)
  child_sku         String?   @db.VarChar(200)
  child_id          Int?
  component_type    String    @default("included_item") @db.VarChar(50)
  quantity          Int?
  sort_order        Int       @default(0)
  resolution_status String    @default("unresolved") @db.VarChar(30)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  child             products? @relation("package_child", fields: [child_id], references: [id], onUpdate: NoAction)
  products          products  @relation("package_parent", fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, label], map: "uq_product_package_items_product_label")
  @@index([product_id], map: "idx_product_package_items_product")
  @@index([child_sku], map: "idx_product_package_items_child_sku")
  @@index([child_id], map: "idx_product_package_items_child")
  @@index([resolution_status], map: "idx_product_package_items_resolution")
}

model product_variant_groups {
  id           Int        @id @default(autoincrement())
  group_key    String     @unique @db.VarChar(100)
  base_sku     String?    @db.VarChar(100)
  variant_type String     @db.VarChar(50)
  label        String?    @db.VarChar(200)
  axes         Json       @default("[]")
  source       String     @default("manual") @db.VarChar(50)
  confidence   String     @default("medium") @db.VarChar(20)
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  updated_at   DateTime   @default(now()) @db.Timestamptz(6)
  products     products[]

  @@index([base_sku], map: "idx_product_variant_groups_base_sku")
  @@index([variant_type], map: "idx_product_variant_groups_type")
}

model product_descriptions {
  id           Int      @id @default(autoincrement())
  product_id   Int      @unique
  raw_html     String?
  clean_html   String?
  clean_issues String[] @default([])
  source       String   @default("manual") @db.VarChar(50)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
  products     products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([source], map: "idx_product_descriptions_source")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model redirects {
  id          Int       @id @default(autoincrement())
  old_url     String    @unique @db.VarChar(500)
  new_url     String    @db.VarChar(500)
  status_code Int?      @default(301)
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model quote_requests {
  id            Int           @id @default(autoincrement())
  name          String        @db.VarChar(100)
  phone         String        @db.VarChar(20)
  email         String?       @db.VarChar(200)
  message       String?
  status        String        @default("pending") @db.VarChar(20)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)
  quote_number  String?       @unique @db.VarChar(30)
  admin_notes   String?
  customer_id   Int?
  shipping_fee  Decimal       @default(0) @db.Decimal(15, 2)
  vat_rate      Int           @default(10)
  assigned_to   Int?
  quote_items   quote_items[]
  assigned_user admin_users?  @relation("quote_assigned_to", fields: [assigned_to], references: [id], onUpdate: NoAction)
  customers     customers?    @relation(fields: [customer_id], references: [id], onUpdate: NoAction)

  @@index([quote_number], map: "idx_quote_requests_number")
  @@index([created_at(sort: Desc)], map: "idx_quote_requests_created")
  @@index([status], map: "idx_quote_requests_status")
  @@index([phone], map: "idx_quote_requests_phone")
  @@index([customer_id], map: "idx_quote_requests_customer")
  @@index([assigned_to], map: "idx_quote_requests_assigned")
}

model quote_items {
  id               Int            @id @default(autoincrement())
  quote_id         Int
  product_id       Int
  quantity         Int            @default(1)
  note             String?        @db.VarChar(500)
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  admin_quantity   Int?
  admin_unit_price Decimal?       @db.Decimal(15, 2)
  products         products       @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  quote_requests   quote_requests @relation(fields: [quote_id], references: [id], onDelete: Cascade)

  @@index([quote_id], map: "idx_quote_items_quote")
  @@index([product_id], map: "idx_quote_items_product")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model customers {
  id                 Int              @id @default(autoincrement())
  full_name          String           @db.VarChar(200)
  phone              String           @unique @db.VarChar(20)
  email              String?          @db.VarChar(200)
  source             String?          @default("MANUAL") @db.VarChar(50)
  notes              String?
  last_interacted_at DateTime?        @default(now()) @db.Timestamptz(6)
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  updated_at         DateTime         @default(now()) @db.Timestamptz(6)
  quote_requests     quote_requests[]

  @@index([phone], map: "idx_customers_phone")
  @@index([last_interacted_at(sort: Desc)], map: "idx_customers_interaction")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_categories {
  id              Int          @id @default(autoincrement())
  name            String       @db.VarChar(100)
  slug            String       @unique @db.VarChar(100)
  description     String?
  thumbnail_url   String?
  is_active       Boolean      @default(true)
  sort_order      Int          @default(0)
  seo_title       String?      @db.VarChar(200)
  seo_description String?      @db.VarChar(500)
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime     @default(now()) @db.Timestamptz(6)
  blog_posts      blog_posts[]

  @@index([slug], map: "idx_blog_categories_slug")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_post_tags {
  post_id    Int
  tag_id     Int
  blog_posts blog_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  blog_tags  blog_tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, tag_id])
  @@index([post_id], map: "idx_blog_post_tags_post")
  @@index([tag_id], map: "idx_blog_post_tags_tag")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model blog_posts {
  id              Int              @id @default(autoincrement())
  title           String           @db.VarChar(300)
  slug            String           @unique @db.VarChar(300)
  excerpt         String?
  content         String           @default("")
  category_id     Int
  thumbnail_url   String?
  cover_image_url String?
  seo_title       String?          @db.VarChar(200)
  seo_description String?          @db.VarChar(500)
  seo_keywords    String?          @db.VarChar(500)
  reading_time    Int?
  view_count      Int              @default(0)
  status          String           @default("draft") @db.VarChar(20)
